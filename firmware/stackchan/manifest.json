{
  "defines": {
    "XS_MODS": 1
  },
  "include": [
    "$(MODDABLE)/examples/manifest_base.json",
    "$(MODDABLE)/examples/manifest_typings.json",
    "$(MODDABLE)/examples/manifest_net.json",
    "$(MODULES)/base/modules/manifest.json",
    "$(MODULES)/data/crc/manifest.json",
    "./drivers/manifest_driver.json",
    "./ble/manifest_ble.json",
    "./dialogues/manifest_dialogue.json",
    "./led/manifest_led.json",
    "./renderers-piu/manifest_renderer_piu.json",
    "./services/manifest_service.json",
    "./speeches/manifest_speech.json",
    "./transcriptions/manifest_transcription.json",
    "./utilities/manifest_utility.json",
    "./manifest_typings.json",
    "./manifest_microphone.json"
  ],
  "modules": {
    "*": [
      "./touch",
      "./robot",
      "./tone",
      "./main",
      "$(MODULES)/network/http/*"
    ],
    "default-mods/*": "./default-mods/*"
  },
  "preload": ["robot", "touch", "tone"],
  "strip": [],
  "creation": {
    "static": 110592,
    "chunk": {
      "initial": 1536,
      "incremental": 512
    },
    "heap": {
      "initial": 512,
      "incremental": 64
    },
    "stack": 512,
    "keys": {
      "available": 512
    }
  },
  "config": {
    "sntp": "pool.ntp.org",
    "driver": {
      "panId": 1,
      "tiltId": 2,
      "pwmPan": 5,
      "pwmTilt": 2,
      "offsetTilt": 0,
      "offsetPan": 0
    },
    "serial": {
      "transmit": 17,
      "receive": 16
    }
  },
  "resources": {
    "*-mask": ["$(MODDABLE)/examples/assets/fonts/OpenSans-Regular-24"]
  },
  "bundle": {
    "id": "tech.moddable.stackchan",
    "devices": [
      "com.m5stack",
      "com.m5stack.fire",
      "com.m5stack.core2",
      "com.m5stack.cores3"
    ]
  },
  "platforms": {
    "esp32/m5stack_core2": {
      "creation": {
        "static": 442368,
        "chunk": {
          "initial": 8192,
          "incremental": 2048
        },
        "heap": {
          "initial": 512,
          "incremental": 64
        },
        "stack": 512,
        "keys": {
          "available": 512
        }
      },
      "config": {
        "driver": {
          "pwmPan": 19,
          "pwmTilt": 27
        },
        "tts": {
          "sampleRate": 24000
        },
        "serial": {
          "transmit": 14,
          "receive": 13
        }
      }
    },
    "esp32/m5stack_cores3": {
      "build": {
        "PARTITIONS_FILE": "./sdkconfig/customPartitions.csv"
      },
      "config": {
        "driver": {
          "type": "dynamixel",
          "panId": 1,
          "tiltId": 2
        },
        "tts": {
          "sampleRate": 24000
        },
        "serial": {
          "transmit": 7,
          "receive": 6
        },
        "virtualButton": false
      }
    },
    "esp32/m5atom_s3": {
      "config": {
        "renderer": {
          "type": "small-face"
        },
        "driver": {
          "type": "none"
        }
      }
    },
    "esp32/m5atom_s3r": {
      "config": {
        "renderer": {
          "type": "small-face"
        },
        "driver": {
          "type": "none"
        }
      }
    },
    "esp32/m5atom_s3_echo_base": {
      "config": {
        "renderer": {
          "type": "small-face"
        },
        "driver": {
          "type": "none"
        }
      }
    },
    "esp32/m5atom_s3r_echo_base": {
      "config": {
        "renderer": {
          "type": "small-face"
        },
        "driver": {
          "type": "none"
        }
      }
    },
    "mac/m5stack": {
      "config": {
        "driver": {
          "type": "none"
        }
      }
    },
    "lin/m5stack": {
      "config": {
        "driver": {
          "type": "none"
        }
      }
    },
    "win/m5stack": {
      "config": {
        "driver": {
          "type": "none"
        }
      }
    },
    "mac/m5atom_s3": {
      "config": {
        "renderer": {
          "type": "small-face"
        },
        "driver": {
          "type": "none"
        }
      }
    },
    "lin/m5atom_s3": {
      "config": {
        "renderer": {
          "type": "small-face"
        },
        "driver": {
          "type": "none"
        }
      }
    },
    "win/m5atom_s3": {
      "config": {
        "renderer": {
          "type": "small-face"
        },
        "driver": {
          "type": "none"
        }
      }
    }
  },
  "typescript": {
    "tsconfig": {
      "compilerOptions": {
        "noImplicitAny": false
      }
    }
  }
}
