{
  "include": [
    "$(MODDABLE)/examples/manifest_base.json",
    "$(MODDABLE)/examples/manifest_typings.json",
    "$(MODDABLE)/modules/io/manifest.json",
    "../utilities/manifest_utility.json"
  ],
  "modules": {
    "*": ["./*", "./internal/*"]
  },
  "preload": [
    "dynamixel",
    "dynamixel-driver",
    "m5stackchan-servo",
    "m5stackchan-servo-driver",
    "none-driver",
    "rs30x-driver",
    "scservo-driver",
    "sg90-driver",
    "payload-buffer",
    "internal/single-wait-slot"
  ],
  "typescript": {
    "tsconfig": {
      "compilerOptions": {
        "noImplicitAny": false,
        "strictNullChecks": false,
        "strictPropertyInitialization": false,
        "strictFunctionTypes": false
      }
    }
  }
}
