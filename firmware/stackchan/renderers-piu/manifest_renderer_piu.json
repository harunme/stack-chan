{
  "include": [
    "$(MODDABLE)/examples/manifest_base.json",
    "$(MODDABLE)/examples/manifest_typings.json",
    "$(MODDABLE)/examples/manifest_piu.json",
    "$(MODDABLE)/modules/piu/MC/outline/manifest.json",
    "../utilities/manifest_utility.json"
  ],
  "modules": {
    "renderer-simple": "./renderer-simple",
    "renderer-dog": "./renderer-dog",
    "renderer-small": "./renderer-small",
    "skin-cache": "./skin-cache",
    "shell": "./shell",
    "drawer": "./drawer",
    "decorators/speech-balloon": "./decorators/speech-balloon",
    "decorators/*": "./decorators/*",
    "parts/dog/*": "./parts/dog/*",
    "parts/*": "./parts/*",
    "behaviors/*": "./behaviors/*",
    "*": ["./*"]
  },
  "resources": {
    "*-mask": [
      "$(MODDABLE)/examples/assets/fonts/OpenSans-Regular-20",
      "$(MODDABLE)/examples/assets/fonts/OpenSans-Regular-16"
    ]
  },
  "preload": ["renderer-simple", "renderer-dog", "renderer-small"]
}
