{
  "build": {
    "SUBPLATFORM": "m5stackchan_cores3"
  },
  "include": ["$(BUILD)/devices/esp32/targets/m5stack_cores3/manifest.json"],
  "modules": {
    "m5stack-cores3/setup-target": "$(BUILD)/devices/esp32/targets/m5stack_cores3/setup-target",
    "setup/target": "./setup-target"
  },
  "config": {
    "driver": {
      "type": "m5stackchan",
      "panId": 1,
      "tiltId": 2,
      "yawZeroPosition": 460,
      "pitchZeroPosition": 620,
      "serial": {
        "transmit": 6,
        "receive": 7,
        "port": 1,
        "baud": 1000000
      },
      "servoPower": {
        "type": "py32",
        "pin": 0,
        "address": 111
      }
    },
    "led": {
      "head": {
        "type": "py32",
        "length": 12,
        "ledPin": 13,
        "address": 111
      }
    },
    "serial": {
      "transmit": 6,
      "receive": 7,
      "port": 1,
      "baud": 1000000
    },
    "touchIntervalMs": 50,
    "virtualButton": false
  }
}
