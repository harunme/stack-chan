{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-tests",
    "allowJs": false,
    "allowImportingTsExtensions": false,
    "checkJs": false,
    "noEmit": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "stackchan/drivers/payload-buffer.ts",
    "stackchan/drivers/internal/single-wait-slot.ts",
    "stackchan/drivers/__tests__/**/*.ts",
    "tests/unit/**/*.ts"
  ],
  "exclude": []
}
